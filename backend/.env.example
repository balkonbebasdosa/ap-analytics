# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS connection string.
# When using docker-compose, port is 5433 (mapped from container's 5432).
DATABASE_URL="postgresql://postgres:password@localhost:5433/ap_analytics?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Any long random string — used to sign JWT tokens. Change before deploying.
JWT_SECRET="change-me-to-a-long-random-secret"

# ── Google APIs ───────────────────────────────────────────────────────────────
# Required: enable "Places API (New)" and "Geocoding API" in Google Cloud Console.
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ── Optional ──────────────────────────────────────────────────────────────────
# GEMINI_API_KEY="your-gemini-api-key"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL="http://localhost:5173"
