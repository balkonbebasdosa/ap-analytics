# ── API ───────────────────────────────────────────────────────────────────────
# Backend base URL. In development, Vite proxies /api to localhost:4000 via
# vite.config.ts, so you can leave this blank. Set it for staging/production.
# VITE_API_URL="http://localhost:4000/api"

# ── Google Maps ───────────────────────────────────────────────────────────────
# Shown in-browser for MapPicker and CompetitorMap.
# Restrict this key to HTTP referrers (your domain) in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
