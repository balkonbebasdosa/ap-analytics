# Root .env — used by docker-compose to inject secrets into containers.
# Copy to .env and fill in real values before running `docker compose up`.

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-secret"

# ── Google APIs ───────────────────────────────────────────────────────────────
# Backend key — enable "Places API (New)" and "Geocoding API".
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Frontend key — enable "Maps JavaScript API". Restrict to HTTP referrers.
VITE_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ── Optional ──────────────────────────────────────────────────────────────────
# GEMINI_API_KEY="your-gemini-api-key"
